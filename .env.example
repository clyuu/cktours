GEMINI_API_KEY=your_gemini_api_key

# Frontend: use this when deploying frontend to GitHub Pages.
# Example: https://cktours-api.onrender.com
VITE_API_BASE_URL=

# Backend (when deploying API server)
# Example: https://clyuu.github.io,https://www.cktours.com
CORS_ORIGIN=

# Backend SQLite file location in production.
# Local default remains data/feedback.db if this is empty.
SQLITE_DB_PATH=
