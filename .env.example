GEMINI_API_KEY=your_gemini_api_key

# Shared reviews using JSONBin (no backend required)
# Create a bin and add its ID here.
VITE_JSONBIN_BIN_ID=

# JSONBin API key (Master Key or Access Key depending on your bin permissions)
VITE_JSONBIN_API_KEY=

# Optional secondary access key
VITE_JSONBIN_ACCESS_KEY=

# Legacy backend mode (optional)
# Frontend: use this when deploying frontend to GitHub Pages.
# Example: https://cktours-api.onrender.com
VITE_API_BASE_URL=

# Backend (when deploying API server)
# Example: https://clyuu.github.io,https://www.cktours.com
CORS_ORIGIN=

# Backend SQLite file location in production.
# Local default remains data/feedback.db if this is empty.
SQLITE_DB_PATH=
